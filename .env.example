# Database Configuration (Docker PostgreSQL)
DATABASE_URL=postgresql://skincare_user:skincare_pass_2024@localhost:5433/skincare_ecommerce

# Paystack Configuration
# Get your public key from https://dashboard.paystack.com/#/settings/developer
PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# Cloudinary Configuration (for image uploads)
# Sign up at https://cloudinary.com for free account
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Or use local file storage (set to 'local' or 'cloudinary')
IMAGE_STORAGE=local

# Application
PUBLIC_SITE_URL=http://localhost:4321

# Email Service (Choose one)
# Option 1: Resend (Recommended) - Get key from https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Option 2: Gmail with Nodemailer
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password

# Option 3: SendGrid
# SENDGRID_API_KEY=SG.your_api_key_here
